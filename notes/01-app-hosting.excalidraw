      "updated": 1778523518623,
      "link": null,
      "locked": false,
      "text": "Jeff's definition of a Microservice:\n- any service that a team can deploy any time they wan't without coordination from other teams.\n- No other team should be able to deploy something that will break your service.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Jeff's definition of a Microservice:\n- any service that a team can deploy any time they wan't without coordination from other teams.\n- No other team should be able to deploy something that will break your service.",
      "autoResize": true,
      "lineHeight": 1.25
    }
