      "link": null,
      "locked": false,
      "text": "\"Backing Services\"\n(databases, email,\nother team's\nservices, etc.)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "yhyskBW-ZrTMPhxhM5TxF",
      "originalText": "\"Backing Services\"\n(databases, email, other team's services, etc.)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "p73z4M04LUZohMwCzAKXe",
      "type": "text",
      "x": 1232,
      "y": 525,
      "width": 704,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aW",
      "roundness": null,
      "seed": 621586490,
      "version": 162,
      "versionNonce": 1467320742,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1778521759642,
      "link": null,
      "locked": false,
      "text": "Backing Services are late bound.\n    - they have a different rate of change than our application.\n    - we can't rely on a specific implementation.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Backing Services are late bound.\n    - they have a different rate of change than our application.\n    - we can't rely on a specific implementation.",
      "autoResize": true,
      "lineHeight": 1.25
    },
