      "roundness": null,
      "seed": 1757260526,
      "version": 751,
      "versionNonce": 1072058670,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1778685797546,
      "link": null,
      "locked": false,
      "text": "Remote Procedure Calls\n    - HTTP\n    - Synchronous\n    - Positives:\n        - Easy to understand\n        - Instrumentation, Security, well understood\n    - Negatives\n        - SYNCHRONOUS - Timing is at the whim of the provider.\n        - HTTP has weak contracts. JSON? Are you kidding me? \n        - Failures can be viral - like a prarie fire.\n        - \n\nAsynchronous Messaging\n    - Not connected\n    - A go between - queue, broker, etc. (delegate)\n    - Negatives\n        - Need some more software\n        - Your brain has to be retuned.\n        - Most models are \"eventual consistency\"\n            - I have been trying to retune your brain with the \"problem\" thing.\n\n    - Positives are pretty much all the negatives of RPCs go away.\n    \nShared Database\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Remote Procedure Calls\n    - HTTP\n    - Synchronous\n    - Positives:\n        - Easy to understand\n        - Instrumentation, Security, well understood\n    - Negatives\n        - SYNCHRONOUS - Timing is at the whim of the provider.\n        - HTTP has weak contracts. JSON? Are you kidding me? \n        - Failures can be viral - like a prarie fire.\n        - \n\nAsynchronous Messaging\n    - Not connected\n    - A go between - queue, broker, etc. (delegate)\n    - Negatives\n        - Need some more software\n        - Your brain has to be retuned.\n        - Most models are \"eventual consistency\"\n            - I have been trying to retune your brain with the \"problem\" thing.\n\n    - Positives are pretty much all the negatives of RPCs go away.\n    \nShared Database\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
