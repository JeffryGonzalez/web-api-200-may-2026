{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
  
      "Route1": {
        "ClusterId": "helpDesk",
        "Match": {
          "Path": "/help-desk/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/help-desk"
          }
        ] 
      },
      "Route2": {
        "ClusterId": "vips",
        "Match": {
          "Path": "/managers/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/managers"
          }
        ] 
      }
    },
    "Clusters": {
      "helpDesk": {
        "Destinations": {
          "helpDesk": {
            "Address": "https://help-desk"
          }
        }
      },
      "vips": {
        "Destinations": {
          "vips": {
            "Address": "https://vips-api"
          }
        }
      }
    }
  }
}
