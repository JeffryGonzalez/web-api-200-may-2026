{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
  
      "Route1": {
        "ClusterId": "helpDesk",
        "Match": {
          "Path": "/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "helpDesk": {
        "Destinations": {
          "helpDesk": {
            "Address": "https://help-desk"
          }
        }
      },
      "vips": {
        "Destinations": {
          "vips": {
            "Address": "https://vips-api"
          }
        }
      }
    }
  }
}
